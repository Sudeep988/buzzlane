<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>BuzzLane - Coming Soon</title>

<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:#050505;
color:#fff;
font-family:'Inter',sans-serif;
overflow-x:hidden;
}

.hero{
min-height:100vh;
position:relative;
display:flex;
align-items:center;
}

.hero::before{
content:'';
position:absolute;
inset:0;
background:
linear-gradient(to right, rgba(0,0,0,.85), rgba(0,0,0,.45)),
url('https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=2000');
background-size:cover;
background-position:center;
}

.container{
position:relative;
z-index:2;
max-width:1200px;
margin:auto;
padding:50px 24px;
width:100%;
}

.logo{
font-family:'Barlow Condensed',sans-serif;
font-size:72px;
font-weight:800;
color:#ffd400;
letter-spacing:1px;
}

.category{
margin-top:10px;
letter-spacing:6px;
color:#ffd400;
font-size:14px;
}

.line{
width:90px;
height:4px;
background:#ffd400;
margin:40px 0;
}

h1{
font-family:'Barlow Condensed',sans-serif;
font-size:120px;
line-height:.9;
font-weight:800;
}

.sub{
font-size:22px;
letter-spacing:8px;
margin-top:20px;
color:#ffd400;
}

.desc{
margin-top:30px;
max-width:500px;
font-size:24px;
line-height:1.5;
color:#e8e8e8;
}

.launch{
margin-top:70px;
letter-spacing:6px;
color:#999;
}

.countdown{
display:flex;
gap:25px;
margin-top:25px;
flex-wrap:wrap;
}

.box{
width:130px;
height:130px;
border:1px solid rgba(255,212,0,.5);
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
backdrop-filter:blur(10px);
}

.box span{
font-family:'Barlow Condensed',sans-serif;
font-size:72px;
font-weight:700;
}

.box small{
letter-spacing:3px;
color:#aaa;
}

.notify-title{
margin-top:70px;
letter-spacing:6px;
color:#ffd400;
}

.form{
display:flex;
margin-top:20px;
max-width:750px;
gap:15px;
flex-wrap:wrap;
}

input{
flex:1;
padding:20px;
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.15);
color:white;
font-size:18px;
}

button{
padding:20px 45px;
border:none;
background:#ffd400;
color:black;
font-family:'Barlow Condensed',sans-serif;
font-size:22px;
font-weight:700;
cursor:pointer;
letter-spacing:2px;
}

.footer-tags{
margin-top:70px;
display:flex;
gap:20px;
flex-wrap:wrap;
}

.tag{
border:1px solid rgba(255,212,0,.4);
padding:12px 25px;
letter-spacing:3px;
}

.success{
margin-top:15px;
color:#7dff8f;
}

@media(max-width:768px){

.logo{
font-size:48px;
}

h1{
font-size:70px;
}

.sub{
font-size:18px;
letter-spacing:4px;
}

.desc{
font-size:18px;
}

.box{
width:90px;
height:90px;
}

.box span{
font-size:42px;
}

.form{
flex-direction:column;
}

button{
width:100%;
}
}

</style>
</head>
<body>

<section class="hero">

<div class="container">

<div class="logo">BUZZLANE</div>

<div class="category">
AUTO • TRAVEL • LIFESTYLE
</div>

<div class="line"></div>

<h1>BUZZLANE</h1>

<div class="sub">
AUTO • TRAVEL • LIFESTYLE
</div>

<div class="desc">
The magazine for those who move differently.
Launching soon.
</div>

<div class="launch">
LAUNCHING IN
</div>

<div class="countdown">

<div class="box">
<span id="days">10</span>
<small>DAYS</small>
</div>

<div class="box">
<span id="hours">00</span>
<small>HOURS</small>
</div>

<div class="box">
<span id="minutes">00</span>
<small>MINUTES</small>
</div>

<div class="box">
<span id="seconds">00</span>
<small>SECONDS</small>
</div>

</div>

<div class="notify-title">
BE THE FIRST TO KNOW
</div>

<form class="form" id="notifyForm">

<input
type="email"
placeholder="your@email.com"
required
>

<button>
NOTIFY ME
</button>

</form>

<div class="success" id="success"></div>

<div class="footer-tags">
<div class="tag">AUTO</div>
<div class="tag">TRAVEL</div>
<div class="tag">LIFESTYLE</div>
</div>

</div>

</section>

<script>

const launchDate = new Date();
launchDate.setDate(launchDate.getDate()+10);

function updateCountdown(){

const now = new Date().getTime();
const distance = launchDate-now;

const days = Math.floor(distance/(1000*60*60*24));
const hours = Math.floor((distance%(1000*60*60*24))/(1000*60*60));
const minutes = Math.floor((distance%(1000*60*60))/(1000*60));
const seconds = Math.floor((distance%(1000*60))/1000);

document.getElementById("days").innerText=days;
document.getElementById("hours").innerText=hours;
document.getElementById("minutes").innerText=minutes;
document.getElementById("seconds").innerText=seconds;

}

setInterval(updateCountdown,1000);
updateCountdown();

document.getElementById('notifyForm').addEventListener('submit',function(e){

e.preventDefault();

document.getElementById('success').innerHTML =
'✓ Thanks for joining the BuzzLane launch list.';

});

</script>

</body>
</html>
